# Copiar a .env y completar con valores reales. Nunca commitear .env.

ENVIRONMENT=dev

# postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://deliverypilot:deliverypilot@localhost:5432/deliverypilot

# Base de datos separada para la suite de tests (evita pisar datos de dev/seed)
TEST_DATABASE_URL=postgresql+asyncpg://deliverypilot:deliverypilot@localhost:5432/deliverypilot_test

REDIS_URL=redis://localhost:6379/0

# openssl rand -hex 32
JWT_SECRET=change-me-in-env-never-in-code
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fase 1+
FCM_CREDENTIALS_JSON=

# Fase 3
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

SENTRY_DSN=
