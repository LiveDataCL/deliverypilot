# Copiar a .env y completar con valores reales. Nunca commitear .env.

ENVIRONMENT=dev

# DATABASE_URL / TEST_DATABASE_URL: the app's and the test suite's runtime
# role. Deliberately NOT the bootstrap superuser (deliverypilot) — superusers
# bypass Row-Level Security unconditionally, which would make every RLS policy
# in migration 0002 silently inert. See db/init/01-create-app-role.sql.
DATABASE_URL=postgresql+asyncpg://deliverypilot_app:deliverypilot_app@localhost:5432/deliverypilot
TEST_DATABASE_URL=postgresql+asyncpg://deliverypilot_app:deliverypilot_app@localhost:5432/deliverypilot_test

# MIGRATIONS_DATABASE_URL / TEST_MIGRATIONS_DATABASE_URL: used only by Alembic.
# Must be the bootstrap superuser (deliverypilot) — it owns every table and
# needs privileges deliverypilot_app doesn't have (CREATE TABLE/TYPE, ALTER
# TABLE ... FORCE ROW LEVEL SECURITY, CREATE POLICY).
MIGRATIONS_DATABASE_URL=postgresql+asyncpg://deliverypilot:deliverypilot@localhost:5432/deliverypilot
TEST_MIGRATIONS_DATABASE_URL=postgresql+asyncpg://deliverypilot:deliverypilot@localhost:5432/deliverypilot_test

REDIS_URL=redis://localhost:6379/0

# openssl rand -hex 32
JWT_SECRET=change-me-in-env-never-in-code
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fase 1+
FCM_CREDENTIALS_JSON=

# Fase 3
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

SENTRY_DSN=
